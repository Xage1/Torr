generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  phone        String?
  role         Role     @default(CUSTOMER)

  // Account Status
  verified         Boolean   @default(false)
  failedAttempts   Int       @default(0)
  lockedUntil      DateTime?
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  orders             Order[]
  RefreshTokens      RefreshToken[]
  LoginSessions      LoginSession[]
  AuditLogs          AuditLog[]
  EmailVerifications EmailVerification[]

  @@map("users")
}

model Product {
  id          Int     @id @default(autoincrement())
  title       String
  description String?

  price Decimal @db.Decimal(12, 2)
  stock Int     @default(0)

  category String?

  source String @default("MANUAL")

  externalId String? @unique
  link       String?

  mainImage String?
  imageUrls String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  OrderItem OrderItem[]
}

model Order {
  id Int @id @default(autoincrement())

  orderNumber String @unique

  user   User? @relation(fields: [userId], references: [id])
  userId Int?

  status OrderStatus @default(CREATED)

  total Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  OrderItem OrderItem[]

  Payment Payment?

  Invoice Invoice?

  @@map("orders")
}

model OrderItem {
  id Int @id @default(autoincrement())

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId Int

  product   Product @relation(fields: [productId], references: [id])
  productId Int

  quantity Int

  // Snapshot of the product price at purchase time
  price Decimal @db.Decimal(12, 2)
}

model Payment {
  id Int @id @default(autoincrement())

  orderId Int @unique

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  method String

  amount Decimal @db.Decimal(12, 2)

  status PaymentStatus @default(PENDING)

  checkoutRequestId String? @unique

  merchantRequestId String?

  mpesaReceiptNumber String? @unique

  phoneNumber String?

  transactionDate DateTime?

  resultCode Int?

  resultDescription String?

  rawCallback Json?

  audits PaymentAudit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

model Invoice {
  id Int @id @default(autoincrement())

  invoiceNumber String @unique

  orderId Int @unique

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  subtotal Decimal @db.Decimal(12, 2)

  tax Decimal @db.Decimal(12, 2)

  total Decimal @db.Decimal(12, 2)

  paid Boolean @default(false)

  pdfPath String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("invoices")
}

model PaymentAudit {
  id Int @id @default(autoincrement())

  paymentId Int

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  action String

  payload Json?

  createdAt DateTime @default(now())

  @@map("payment_audit")
}

model ScrapingJob {
  id Int @id @default(autoincrement())

  source String

  status ScrapeStatus @default(RUNNING)

  runAt DateTime @default(now())

  message String?
}

model Whitelist {
  id Int @id @default(autoincrement())

  email String? @unique
  phone String? @unique

  createdAt DateTime @default(now())
}

model RefreshToken {
  id Int @id @default(autoincrement())

  token String @unique

  userId Int

  user User @relation(fields:[userId],references:[id])

  expiresAt DateTime

  revoked Boolean @default(false)

  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model LoginSession {

  id Int @id @default(autoincrement())

  userId Int

  user User @relation(fields:[userId],references:[id])

  device String?

  browser String?

  os String?

  ip String?

  location String?

  lastSeen DateTime @default(now())

  refreshToken String?

  active Boolean @default(true)

  createdAt DateTime @default(now())

  @@map("login_sessions")
}

model AuditLog {

  id Int @id @default(autoincrement())

  userId Int?

  user User? @relation(fields:[userId],references:[id])

  action String

  entity String?

  entityId String?

  ip String?

  payload Json?

  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model PasswordReset {

  id Int @id @default(autoincrement())

  email String

  token String @unique

  expiresAt DateTime

  used Boolean @default(false)

  createdAt DateTime @default(now())

  @@map("password_resets")
}

model EmailVerification {

  id Int @id @default(autoincrement())

  userId Int

  user User @relation(fields:[userId],references:[id])

  token String @unique

  expiresAt DateTime

  verified Boolean @default(false)

  @@map("email_verifications")
}

enum Role {
  ADMIN
  CUSTOMER
}

enum OrderStatus {
  CREATED
  AWAITING_PAYMENT
  PAID
  PROCESSING
  READY_FOR_PICKUP
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  STK_SENT
  PROCESSING
  SUCCESS
  FAILED
  TIMEOUT
  CANCELLED
  REFUNDED
}

enum ScrapeStatus {
  RUNNING
  SUCCESS
  FAILED
}
